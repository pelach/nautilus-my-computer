#——————————————————————————————
# Preferences - Panel visibility
#——————————————————————————————

msgid "Panel visibility"
msgstr "Visibilidad del panel"

msgid "Choose how each group appears. Visible: shows the group as a normal separated section. Merged: folds the group into the On this Computer group. Hidden: hides the group entirely."
msgstr "Elige cómo aparece cada grupo. Visible: muestra el grupo como una sección separada normal. Fusionado: agrupa las entradas en el grupo En este equipo. Oculto: oculta el grupo por completo."

msgid "Visible"
msgstr "Visible"

msgid "Merged"
msgstr "Fusionado"

msgid "Hidden"
msgstr "Oculto"

