#——————————————————————————————
# Preferences - Panel visibility
#——————————————————————————————

msgid "Panel visibility"
msgstr "Visibilitat del panell"

msgid "Choose how each group appears. Visible: shows the group as a normal separated section. Merged: folds the group into the On this Computer group. Hidden: hides the group entirely."
msgstr "Trieu com apareix cada grup. Visible: mostra el grup com una secció separada normal. Integrat: integra el grup dins del grup En aquest ordinador. Ocult: amaga completament el grup."

msgid "Visible"
msgstr "Visible"

msgid "Merged"
msgstr "Integrat"

msgid "Hidden"
msgstr "Ocult"

