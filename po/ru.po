#——————————————————————————————
# Preferences - Visibility
#——————————————————————————————

msgid "Panel visibility"
msgstr "Видимость панелей"

msgid "Choose how each group appears. Visible: shows the group as a normal separated section. Merged: folds the group into the On this Computer group. Hidden: hides the group entirely."
msgstr "Выберите, как будет отображаться каждая группа. Показать: показывает группу как обычную отдельную секцию. Объединить: Объединяет группу вместе с группой на этом компьютере. Спрятать: прячет группу полностью."

msgid "Sidebar visibility"
msgstr "Видимость элементов боковой панели"

msgid "Choose which locations appear on the sidebar."
msgstr "Выберите, какие места будут отображаться на боковой панели."

msgid "Visible"
msgstr "Показать"

msgid "Merged"
msgstr "Объединить"

msgid "Hidden"
msgstr "Спрятать"

