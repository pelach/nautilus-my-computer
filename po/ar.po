msgstr "لون النهاية"

#——————————————————————————————
# Preferences - Panel visibility
#——————————————————————————————

msgid "Panel visibility"
msgstr "ظهور اللوحة"

msgid "Choose how each group appears. Visible: shows the group as a normal separated section. Merged: folds the group into the On this Computer group. Hidden: hides the group entirely."
msgstr "اختر كيفية ظهور كل مجموعة. ظاهر: يظهر المجموعة كقسم منفصل عادي. مدمج: يطوي المجموعة ضمن مجموعة \"على هذا الكمبيوتر\". مخفي: يخفي المجموعة تماماً."

msgid "Visible"
msgstr "ظاهر"

msgid "Merged"
msgstr "مدمج"

msgid "Hidden"
msgstr "مخفي"

#——————————————————————————————
# Preferences - System
#——————————————————————————————

msgid "Show system partitions"
msgstr "إظهار أقسام النظام"

msgid "Include boot and EFI partitions in the System group"
msgstr "تضمين أقسام الإقلاع و EFI في مجموعة النظام"

