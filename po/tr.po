# ——————————————————————————————
# Preferences - Panel visibility
# ——————————————————————————————
# Previous translation (before rename from "Visibility"): Görünürlük
msgid "Panel visibility"
msgstr ""

msgid ""
"Choose how each group appears. Visible: shows the group as a normal "
"separated section. Merged: folds the group into the On this Computer group. "
"Hidden: hides the group entirely."
msgstr ""
"Her grubun nasıl görüneceğini seçin. Görünür: grubu normal, ayrı bir bölüm "
"olarak gösterir. Birleştirilmiş: grubu Bu Bilgisayarda grubunun içine "
"toplar. Gizli: grubu tamamen gizler."

msgid "Visible"
msgstr "Görünür"

msgid "Merged"
msgstr "Birleştirilmiş"

msgid "Hidden"
msgstr "Gizli"

