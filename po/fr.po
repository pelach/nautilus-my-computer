#——————————————————————————————
# Preferences - Panel visibility
#——————————————————————————————

msgid "Panel visibility"
msgstr "Visibilité du panneau"

msgid "Choose how each group appears. Visible: shows the group as a normal separated section. Merged: folds the group into the On this Computer group. Hidden: hides the group entirely."
msgstr "Choisir comment chaque groupe s'affiche. Visible : affiche le groupe comme une section séparée normale. Fusionné : ajoute le groupe dans le groupe Sur cet ordinateur. Masqué : masque entièrement le groupe."

msgid "Visible"
msgstr "Visible"

msgid "Merged"
msgstr "Fusionné"

msgid "Hidden"
msgstr "Masqué"

#——————————————————————————————
