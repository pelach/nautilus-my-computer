msgstr "Colore finale"

#——————————————————————————————
# Preferences - Panel visibility
#——————————————————————————————

msgid "Panel visibility"
msgstr "Visibilità del pannello"

msgid "Choose how each group appears. Visible: shows the group as a normal separated section. Merged: folds the group into the On this Computer group. Hidden: hides the group entirely."
msgstr "Scegli come appare ogni gruppo. Visibile: mostra il gruppo come una normale sezione separata. Integrato: unisce il gruppo al gruppo In questo computer. Nascosto: nasconde completamente il gruppo."

msgid "Visible"
msgstr "Visibile"

msgid "Merged"
msgstr "Integrato"

msgid "Hidden"
msgstr "Nascosto"

#——————————————————————————————
# Preferences - System
#——————————————————————————————

msgid "Show system partitions"
msgstr "Mostra le partizioni di sistema"

msgid "Include boot and EFI partitions in the System group"
msgstr "Includi le partizioni di avvio ed EFI nel gruppo Sistema"

#——————————————————————————————
