# Preferences - Bar Color
#——————————————————————————————

msgid "Bar Color"
msgstr "막대 색상"

msgid "Select or customize the bar color."
msgstr "막대 색상을 선택하거나 직접 설정합니다."

msgid "Color mode"
msgstr "색상 모드"

