msgstr "끝 색상"

#——————————————————————————————
# Preferences - Visibility
#——————————————————————————————

msgid "Visibility"
msgstr "표시 여부"

msgid "Choose how each group appears. Visible: shows the group as a normal separated section. Merged: folds the group into the On this Computer group. Hidden: hides the group entirely."
msgstr "각 그룹이 표시되는 방식을 선택합니다. 표시: 그룹을 일반적인 별도 섹션으로 표시합니다. 병합: 그룹을 이 컴퓨터 그룹 안으로 접어 넣습니다. 숨김: 그룹을 완전히 숨깁니다."

msgid "Visible"
msgstr "표시"

msgid "Merged"
msgstr "병합"

msgid "Hidden"
msgstr "숨김"

#——————————————————————————————
# Preferences - System
#——————————————————————————————

msgid "Show system partitions"
msgstr "시스템 파티션 표시"

msgid "Include boot and EFI partitions in the System group"
msgstr "부트 및 EFI 파티션을 시스템 그룹에 포함합니다"

