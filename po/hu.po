# ——————————————————————————————
# Preferences - Panel visibility
# ——————————————————————————————
msgid "Panel visibility"
msgstr "Panel láthatóság"

msgid ""
"Choose how each group appears. Visible: shows the group as a normal "
"separated section. Merged: folds the group into the On this Computer group. "
"Hidden: hides the group entirely."
msgstr ""
"Válassza ki, hogyan jelenjenek meg az egyes csoportok. Látható: a csoportot "
"normál, elkülönített szakaszként jeleníti meg. Egyesített: a csoportot az "
"Ezen a számítógépen csoportba rakja. Rejtett: teljesen elrejti a csoportot."

msgid "Visible"
msgstr "Látható"

msgid "Merged"
msgstr "Egyesített"

msgid "Hidden"
msgstr "Rejtett"

