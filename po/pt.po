#——————————————————————————————
# Preferences - Panel visibility
#——————————————————————————————

msgid "Panel visibility"
msgstr "Visibilidade do painel"

msgid "Choose how each group appears. Visible: shows the group as a normal separated section. Merged: folds the group into the On this Computer group. Hidden: hides the group entirely."
msgstr "Escolha como cada grupo aparece. Visível: mostra o grupo como uma secção separada normal. Integrado: integra o grupo no grupo Neste computador. Oculto: esconde o grupo completamente."

msgid "Visible"
msgstr "Visível"

msgid "Merged"
msgstr "Integrado"

msgid "Hidden"
msgstr "Oculto"

#——————————————————————————————
# Preferences - System
#——————————————————————————————

msgid "Show system partitions"
msgstr "Mostrar partições do sistema"

msgid "Include boot and EFI partitions in the System group"
msgstr "Incluir as partições de arranque e EFI no grupo Sistema"

